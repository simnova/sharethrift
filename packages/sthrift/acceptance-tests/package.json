{
	"name": "@sthrift/acceptance-tests",
	"version": "1.0.0",
	"description": "Cucumber Screenplay acceptance tests for ShareThrift domain",
	"private": true,
	"type": "module",
	"scripts": {
		"test:domain": "LOG_LEVEL=warn NODE_OPTIONS='--import tsx/esm' cucumber-js src/contexts/**/features/**/*.feature --world-parameters '{\"tasks\":\"domain\"}' --import './src/world.ts' --import './src/step-definitions/**/*.ts' --import './src/shared/support/**/*.ts' --format json:./reports/cucumber-report-domain.json",
		"test:session:graphql": "LOG_LEVEL=warn NODE_OPTIONS='--import tsx/esm' cucumber-js src/contexts/**/features/**/*.feature --world-parameters '{\"tasks\":\"session\",\"session\":\"graphql\"}' --import './src/world.ts' --import './src/step-definitions/**/*.ts' --import './src/shared/support/**/*.ts' --format json:./reports/cucumber-report-session-graphql.json",
		"test:session:mongodb": "LOG_LEVEL=warn NODE_OPTIONS='--import tsx/esm' cucumber-js src/contexts/**/features/**/*.feature --world-parameters '{\"tasks\":\"session\",\"session\":\"mongodb\"}' --import './src/world.ts' --import './src/step-definitions/**/*.ts' --import './src/shared/support/**/*.ts' --format json:./reports/cucumber-report-session-mongodb.json",
		"test:e2e": "LOG_LEVEL=warn NODE_OPTIONS='--import tsx/esm' cucumber-js src/contexts/**/features/**/*.feature --world-parameters '{\"tasks\":\"e2e\"}' --import './src/world.ts' --import './src/step-definitions/**/*.ts' --import './src/shared/support/**/*.ts' --format json:./reports/cucumber-report-e2e.json",
		"test:fast": "pnpm run test:domain && pnpm run test:session:graphql",
		"test:all": "pnpm run test:domain && pnpm run test:session:graphql && pnpm run test:session:mongodb && pnpm run test:e2e",
		"playwright:install": "playwright install chromium",
		"clean": "rimraf dist reports target"
	},
	"dependencies": {
		"@cucumber/cucumber": "^11.2.0",
		"@serenity-js/assertions": "^3.37.2",
		"@serenity-js/console-reporter": "^3.37.2",
		"@serenity-js/core": "^3.37.2",
		"@serenity-js/cucumber": "^3.37.2",
		"@serenity-js/serenity-bdd": "^3.37.2",
		"graphql": "^16.12.0",
		"std-env": "^4.0.0"
	},
	"devDependencies": {
		"@apollo/server": "^5.4.0",
		"@cellix/server-oauth2-seedwork": "workspace:*",
		"@cellix/service-messaging-base": "workspace:*",
		"@cellix/service-mongoose": "workspace:*",
		"@cellix/service-payment-base": "workspace:*",
		"@cellix/service-token-validation": "workspace:*",
		"@cellix/typescript-config": "workspace:*",
		"@cucumber/messages": "^32.2.0",
		"@playwright/test": "^1.52.0",
		"@sthrift/application-services": "workspace:*",
		"@sthrift/context-spec": "workspace:*",
		"@sthrift/domain": "workspace:*",
		"@sthrift/graphql": "workspace:*",
		"@sthrift/persistence": "workspace:*",
		"@types/graphql-depth-limit": "^1.1.6",
		"@types/node": "^24.6.1",
		"express": "^4.22.1",
		"graphql-depth-limit": "^1.1.0",
		"graphql-middleware": "^6.1.35",
		"jose": "^5.9.6",
		"mongodb": "^6.15.0",
		"mongodb-memory-server": "^10.2.0",
		"rimraf": "^6.0.1",
		"tsx": "^4.20.3",
		"typescript": "^5.4.5",
		"vite": "^6.3.5"
	}
}
