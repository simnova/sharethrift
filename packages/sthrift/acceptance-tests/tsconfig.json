{
	"extends": "@cellix/typescript-config/node.json",
	"compilerOptions": {
		"outDir": "./dist",
		"rootDir": ".",
		"jsx": "react-jsx",
		"lib": ["ES2023", "DOM", "DOM.Iterable"],
		"erasableSyntaxOnly": false,
		"paths": {
			"@ui-sharethrift/*": ["../../apps/ui-sharethrift/src/*"]
		}
	},
	"include": [
		"src/**/*",
		"features/**/*",
		"../../apps/ui-sharethrift/src/**/*"
	],
	"exclude": [
		"node_modules",
		"**/node_modules",
		"dist",
		"coverage",
		"reports",
		"target"
	]
}
