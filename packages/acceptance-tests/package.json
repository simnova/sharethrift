{
	"name": "@sharethrift/acceptance-tests",
	"version": "1.0.0",
	"description": "Cucumber Screenplay acceptance tests for ShareThrift domain",
	"private": true,
	"type": "module",
	"scripts": {
		"test": "pnpm run test:domain",
		"test:domain": "cucumber-js --world-parameters '{\"tasks\":\"domain\"}' --require-module tsx/esm --import './src/step-definitions/**/*.ts' --import './src/support/**/*.ts' --format json:./reports/cucumber-report-domain.json",
		"test:graphql": "cucumber-js --world-parameters '{\"tasks\":\"graphql\"}' --require-module tsx/esm --import './src/step-definitions/**/*.ts' --import './src/support/**/*.ts' --format json:./reports/cucumber-report-graphql.json",
		"test:dom": "cucumber-js --world-parameters '{\"tasks\":\"dom\"}' --require-module tsx/esm --import './src/step-definitions/**/*.ts' --import './src/support/**/*.ts' --format json:./reports/cucumber-report-dom.json",
		"test:all": "pnpm run test:domain && pnpm run test:graphql && pnpm run test:dom",
		"test:serenity": "pnpm run test:all && pnpm run test:serenity:report",
		"test:serenity:report": "serenity-bdd run --features ./reports",
		"clean": "rimraf dist reports target"
	},
	"dependencies": {
		"@cucumber/cucumber": "^11.2.0",
		"@serenity-js/assertions": "^3.36.1",
		"@serenity-js/console-reporter": "^3.36.1",
		"@serenity-js/core": "^3.36.1",
		"@serenity-js/cucumber": "^3.36.1",
		"@serenity-js/playwright": "^3.36.1",
		"@serenity-js/rest": "^3.36.1",
		"@serenity-js/serenity-bdd": "^3.36.1",
		"@serenity-js/web": "^3.36.1"
	},
	"devDependencies": {
		"@apollo/client": "^3.12.4",
		"@cellix/typescript-config": "workspace:*",
		"@playwright/test": "^1.55.1",
		"@sthrift/domain": "workspace:*",
		"@sthrift/graphql": "workspace:*",
		"@types/node": "^24.6.1",
		"rimraf": "^6.0.1",
		"tsx": "^4.20.3",
		"typescript": "catalog:"
	}
}
