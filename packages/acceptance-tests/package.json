{
	"name": "@sharethrift/acceptance-tests",
	"version": "1.0.0",
	"description": "Cucumber Screenplay acceptance tests for ShareThrift domain",
	"private": true,
	"type": "module",
	"scripts": {
		"test": "pnpm run test:fast",
		"test:fast": "pnpm run test:domain && pnpm run test:session",
		"test:domain": "cucumber-js --world-parameters '{\"tasks\":\"domain\"}' --require-module tsx/esm --import './src/step-definitions/**/*.ts' --import './src/support/**/*.ts' --format json:./reports/cucumber-report-domain.json",
		"test:session": "cucumber-js --world-parameters '{\"tasks\":\"graphql\"}' --require-module tsx/esm --import './src/step-definitions/**/*.ts' --import './src/support/**/*.ts' --format json:./reports/cucumber-report-graphql.json",
		"test:dom": "cucumber-js --world-parameters '{\"tasks\":\"dom\",\"baseUrl\":\"https://localhost:3000\"}' --require-module tsx/esm --import './src/step-definitions/**/*.ts' --import './src/support/**/*.ts' --format json:./reports/cucumber-report-dom.json",
		"test:all": "echo 'Note: Ensure UI is running (pnpm dev --filter @sharethrift/ui-sharethrift) before running DOM tests' && pnpm run test:fast && pnpm run test:dom",
		"test:serenity": "pnpm run test:all && pnpm run test:serenity:report",
		"test:serenity:report": "serenity-bdd run --features ./reports",
		"clean": "rimraf dist reports target"
	},
	"dependencies": {
		"@cucumber/cucumber": "^11.2.0",
		"@serenity-js/assertions": "^3.37.1",
		"@serenity-js/console-reporter": "^3.37.1",
		"@serenity-js/core": "^3.37.1",
		"@serenity-js/cucumber": "^3.37.1",
		"@serenity-js/playwright": "^3.37.1",
		"@serenity-js/serenity-bdd": "^3.37.1",
		"@serenity-js/web": "^3.37.1",
		"graphql": "^16.12.0",
		"graphql-tag": "^2.12.6"
	},
	"devDependencies": {
		"@cellix/typescript-config": "workspace:*",
		"@playwright/test": "^1.58.2",
		"@sthrift/domain": "workspace:*",
		"@sthrift/graphql": "workspace:*",
		"@types/node": "^24.6.1",
		"rimraf": "^6.0.1",
		"tsx": "^4.20.3",
		"typescript": "catalog:"
	}
}
