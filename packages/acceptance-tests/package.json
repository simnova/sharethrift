{
	"name": "@sharethrift/acceptance-tests",
	"version": "1.0.0",
	"description": "Cucumber Screenplay acceptance tests for ShareThrift domain",
	"private": true,
	"type": "module",
	"scripts": {
		"test:domain": "cucumber-js --world-parameters '{\"tasks\":\"domain\"}' --require-module tsx/esm --import './src/step-definitions/**/*.ts' --import './src/support/**/*.ts' --format json:./reports/cucumber-report-domain.json",
		"test:session": "cucumber-js --world-parameters '{\"tasks\":\"session\",\"session\":\"domain\"}' --require-module tsx/esm --import './src/step-definitions/**/*.ts' --import './src/support/**/*.ts' --format json:./reports/cucumber-report-session.json",
		"test:session:graphql": "cucumber-js --world-parameters '{\"tasks\":\"session\",\"session\":\"graphql\"}' --require-module tsx/esm --import './src/step-definitions/**/*.ts' --import './src/support/**/*.ts' --format json:./reports/cucumber-report-session-graphql.json",
		"test:dom": "NODE_OPTIONS='--import ./src/support/register-css.mjs' cucumber-js --world-parameters '{\"tasks\":\"dom\",\"session\":\"domain\"}' --require-module tsx/esm --import './src/step-definitions/**/*.ts' --import './src/support/**/*.ts' --format json:./reports/cucumber-report-dom.json",
		"test:dom:graphql": "NODE_OPTIONS='--import ./src/support/register-css.mjs' cucumber-js --world-parameters '{\"tasks\":\"dom\",\"session\":\"graphql\"}' --require-module tsx/esm --import './src/step-definitions/**/*.ts' --import './src/support/**/*.ts' --format json:./reports/cucumber-report-dom-graphql.json",
		"test:fast": "pnpm run test:domain && pnpm run test:session",
		"test:ui": "pnpm run test:dom && pnpm run test:dom:graphql",
		"test:all": "pnpm run test:domain && pnpm run test:session && pnpm run test:session:graphql && pnpm run test:dom && pnpm run test:dom:graphql",
		"test:serenity": "pnpm run test:all && pnpm run test:serenity:report",
		"test:serenity:report": "serenity-bdd run --features ./reports",
		"clean": "rimraf dist reports target"
	},
	"dependencies": {
		"@cucumber/cucumber": "^11.2.0",
		"@serenity-js/assertions": "^3.37.1",
		"@serenity-js/console-reporter": "^3.37.1",
		"@serenity-js/core": "^3.37.1",
		"@serenity-js/cucumber": "^3.37.1",
		"@serenity-js/playwright": "^3.37.1",
		"@serenity-js/serenity-bdd": "^3.37.1",
		"@serenity-js/web": "^3.37.1",
		"graphql": "^16.12.0",
		"graphql-tag": "^2.12.6"
	},
	"devDependencies": {
		"@ant-design/icons": "^6.1.0",
		"@apollo/server": "^5.4.0",
		"@cellix/typescript-config": "workspace:*",
		"@playwright/test": "^1.58.2",
		"@sthrift/application-services": "workspace:*",
		"@sthrift/domain": "workspace:*",
		"@sthrift/graphql": "workspace:*",
		"@sthrift/ui-components": "workspace:*",
		"@testing-library/react": "^16.0.0",
		"@testing-library/user-event": "^14.5.1",
		"antd": "^5.27.1",
		"@types/express": "^5.0.6",
		"@types/node": "^24.6.1",
		"express": "^5.2.1",
		"graphql-depth-limit": "^1.1.0",
		"graphql-middleware": "^6.1.35",
		"happy-dom": "^16.4.0",
		"react": "^19.0.0",
		"react-dom": "^19.0.0",
		"rimraf": "^6.0.1",
		"tsx": "^4.20.3",
		"typescript": "^5.4.5"
	}
}
